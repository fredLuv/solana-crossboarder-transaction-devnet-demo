{
  "name": "freightflow-fx",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter web exec vite --host 127.0.0.1 --port 4174",
    "dev:api": "pnpm --filter @freightflow/quote-engine dev",
    "dev:blink": "cargo run --manifest-path services/blink-api/Cargo.toml",
    "dev:stack": "pnpm dev:api & pnpm dev:blink & pnpm dev:web",
    "build": "pnpm --filter web build",
    "build:web": "pnpm --filter web build",
    "lint": "pnpm --filter web lint"
  }
}
